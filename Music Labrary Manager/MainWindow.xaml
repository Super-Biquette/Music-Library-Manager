<Window x:Class="MusicLibraryManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Music Library Manager"
        Height="600"
        Width="1000">

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- FILTERS -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Genre:" VerticalAlignment="Center"/>
            <ComboBox Width="120"
                      Margin="5"
                      ItemsSource="{Binding Genres}"
                      SelectedItem="{Binding SelectedGenre}"
                      SelectionChanged="FilterChanged"/>

            <TextBlock Text="Search:" VerticalAlignment="Center"/>
            <TextBox Width="150"
                     Margin="5"
                     TextChanged="SearchChanged"/>

            <Button Content="Sort A-Z"
                    Click="SortAZ_Click"
                    Margin="5"/>

            <Button Content="Sort by Debut Date"
                    Click="SortDate_Click"
                    Margin="5"/>

            <Button Content="View Details"
                    Click="ViewDetails_Click"
                    Margin="5"/>
        </StackPanel>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!-- ARTISTS -->
            <ListBox Grid.Column="0"
                     ItemsSource="{Binding FilteredArtists}"
                     SelectedItem="{Binding SelectedArtist}"/>

            <!-- ALBUMS -->
            <ListBox Grid.Column="1"
                     ItemsSource="{Binding SelectedArtist.Albums}"
                     SelectedItem="{Binding SelectedAlbum}"/>

            <!-- DETAILS -->
            <StackPanel Grid.Column="2" Margin="10">
                <TextBlock Text="Album Details"
                           FontWeight="Bold"
                           FontSize="16"/>

                <TextBlock Text="{Binding SelectedAlbum.ReleaseDate}"/>
                <TextBlock Text="{Binding SelectedAlbum.YearsSinceRelease,
                                  StringFormat=Years since release: {0}}"/>

                <TextBlock Text="Songs:"
                           Margin="0,10,0,0"
                           FontWeight="Bold"/>

                <ListBox ItemsSource="{Binding SelectedAlbum.Songs}"/>
            </StackPanel>

        </Grid>

        <!-- SAVE BUTTON -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center">
            <Button Content="Save"
                    Width="150"
                    Margin="5"
                    Click="Save_Click"/>
        </StackPanel>

    </Grid>
</Window>
