<Window x:Class="MusicLibraryManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Music Library Manager"
        Height="600"
        Width="1000">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="8"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <TabControl>
            <!-- PLAYLIST TAB -->
            <TabItem Header="Library">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- FILTERS -->
                    <StackPanel Orientation="Horizontal">
                        <ComboBox Width="120"
                              ItemsSource="{Binding Genres}"
                              SelectedItem="{Binding SelectedGenre}"/>

                        <TextBox Width="150"
                             Margin="5"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>

                        <Button Content="Sort A-Z" Command="{Binding SortAZCommand}"/>

                        <Button Content="Sort by Date" Command="{Binding SortDateCommand}"/>
                        <Button Content="Previous" Command="{Binding PreviousCommand}" />

                        <Button Content="Play" Command="{Binding PlayCommand}" />

                        <Button Content="Stop" Command="{Binding StopCommand}" />

                        <Button Content="Next" Command="{Binding NextCommand}" />

                        <TextBlock Text="Volume" VerticalAlignment="Center" Margin="10,0,0,0"/>

                        <Slider Minimum="0"
                            Maximum="1"
                            Value="{Binding Volume}"
                            Width="100"/>
                    </StackPanel>

                    <!-- MAIN CONTENT -->
                    <Grid Grid.Row="1">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="3*"/>
                        </Grid.ColumnDefinitions>

                        <!-- ARTISTS -->
                        <ListBox Grid.Column="0"
                             ItemsSource="{Binding FilteredArtists}"
                             SelectedItem="{Binding SelectedArtist}"/>


                        <!-- ALBUMS -->
                        <ListBox Grid.Column="1"
                             ItemsSource="{Binding SelectedArtist.Albums}"
                             SelectedItem="{Binding SelectedAlbum}"/>
                        <!-- SONGS -->
                        <StackPanel Grid.Column="2">

                            <TextBlock Text="Songs"
                                       FontWeight="Bold"
                                       FontSize="16"/>

                            <ListBox ItemsSource="{Binding SelectedAlbum.Songs}"
                                     SelectedItem="{Binding SelectedSong}"/>

                            <Button Content="Add to Playlist"
                                    Command="{Binding AddToPlaylistCommand}"/>

                        </StackPanel>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- API TAB -->
            <TabItem Header="API">
                <StackPanel>

                    <TextBlock Text="Search Online Music"
                               FontSize="16"
                               FontWeight="Bold"/>

                    <StackPanel Orientation="Horizontal">

                        <TextBox Width="200"
                                 Text="{Binding ApiSearchText}"/>

                        <Button Content="Search"
                                Command="{Binding LoadAPICommand}"/>

                        <Button Content="Get Info"
                                Command="{Binding GetSongInfoCommand}"/>

                    </StackPanel>

                    <ListBox ItemsSource="{Binding APISongs}"
                             SelectedItem="{Binding SelectedSong}"/>

                    <Button Content="Add to Playlist"
                            Command="{Binding AddToPlaylistCommand}"/>

                </StackPanel>
            </TabItem>

            <!-- PLAYUST TAB -->
            <TabItem Header="Playlist">
                <StackPanel>

                    <TextBlock Text="My Playlist"
                               FontSize="16"
                               FontWeight="Bold"/>

                    <ListBox ItemsSource="{Binding Playlist}"
                             SelectedItem="{Binding SelectedSong}"/>

                    <StackPanel Orientation="Horizontal">

                        <Button Content="Play" Command="{Binding PlayCommand}"/>
                        <Button Content="Remove"
                                Command="{Binding RemoveFromPlaylistCommand}"/>
                        <Button Content="Save Playlist"
                                Command="{Binding SavePlaylistCommand}" />

                        <Button Content="Load Playlist"
                                Command="{Binding LoadPlaylistCommand}" />

                    </StackPanel>

                </StackPanel>
            </TabItem>
        </TabControl>

    </Grid>
</Window>
