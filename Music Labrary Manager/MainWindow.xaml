<Window x:Class="MusicLibraryManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Music Library Manager"
        Height="600"
        Width="1000">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="8"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- FILTERS -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <ComboBox Width="120"
                      ItemsSource="{Binding Genres}"
                      SelectedItem="{Binding SelectedGenre}"/>
            
            <TextBox Width="150"
                     Margin="5"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>

            <Button Content="Sort A-Z" Command="{Binding SortAZCommand}"/>

            <Button Content="Sort by Date" Command="{Binding SortDateCommand}"/>

            <Button Content="Play" Command="{Binding PlayCommand}" />

            <Button Content="View Details" Command="{Binding ViewDetailsCommand}" />
        </StackPanel>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!-- ARTISTS -->
            <ListBox Grid.Column="0"
                     ItemsSource="{Binding FilteredArtists}"
                     SelectedItem="{Binding SelectedArtist}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                                <TextBlock Text="{Binding Genre}" FontSize="12"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
            </ListBox>
            <!-- ALBUMS -->
            <ListBox Grid.Column="1"
                     ItemsSource="{Binding SelectedArtist.Albums}"
                     SelectedItem="{Binding SelectedAlbum}"/>

            <!-- DETAILS -->
            <StackPanel Grid.Column="2" Margin="10">
                <TextBlock Text="Album Details"
                           FontWeight="Bold"
                           FontSize="16"/>

                <Image Source="{Binding SelectedAlbum.CoverImagePath}" Height="120"/>

                <TextBlock Text="{Binding SelectedAlbum.ReleaseDate}"/>
                <TextBlock Text="{Binding SelectedAlbum.YearsSinceRelease,
                                  StringFormat=Years since release: {0}}"/>

                <TextBlock Text="Songs:"
                           Margin="0,10,0,0"
                           FontWeight="Bold"/>

                <ListBox ItemsSource="{Binding SelectedAlbum.Songs}"
                         SelectedItem="{Binding SelectedSong}"/>
            </StackPanel>

        </Grid>

        <!-- SAVE BUTTON -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center">
            <Button Content="Save"
                    Width="150"
                    Command="{Binding SaveCommand}"/>
        </StackPanel>

    </Grid>
</Window>
